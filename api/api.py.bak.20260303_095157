            vals = [session_token, account_id, sas_id, expires_at, client_ip or None, user_agent or None]
            if table_exists("user_sessions") and column_exists("user_sessions", "device_type"):
                cols.append("device_type")
                vals.append(device_type)
            cur.execute("INSERT INTO public.user_sessions (" + ", ".join(cols) + ") VALUES (" + ", ".join(["%s"] * len(vals)) + ")", vals)
            
            conn.commit()
            cur.close()
            conn.close()
            
            # Redirect directly to landing page with session token
            # Use HTTP (8081) for the landing page
            landing_url = f"http://192.168.0.130:8081/index.html?session={session_token}"
            return RedirectResponse(landing_url)
        else:
            # New user - redirect to confirmation page to search for real SAS ID
            # DO NOT create temporary accounts - must link to real SAS ID
            conn.close()
            
            # Save profile picture if available (for later use after linking)
            profile_pic_path = None
            if picture_url:
