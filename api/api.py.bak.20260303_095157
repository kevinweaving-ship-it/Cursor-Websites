                SELECT DISTINCT reg.regatta_id, reg.event_name, reg.start_date
                FROM regattas reg
                JOIN results r ON r.regatta_id = reg.regatta_id
                WHERE reg.host_club_id = %s
                ORDER BY reg.start_date DESC NULLS LAST
            """, (club_id,))
            for r in cur.fetchall() or []:
