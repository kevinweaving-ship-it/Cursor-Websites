#!/usr/bin/expect -f
# 1) SELECT regatta 385 dates; 2) UPDATE start_date/end_date to real event dates.
# From project root: expect sailingsa/deploy/fix-live-regatta-385-dates.exp
set timeout 30
set password "TimAdd#072082"
set server "102.218.215.253"
set user "root"

spawn ssh -o StrictHostKeyChecking=no ${user}@${server} "psql postgresql://sailors_user:SailSA_Pg_Beta2026!@localhost:5432/sailors_master -c \"SELECT regatta_id, start_date, end_date, as_at_time FROM regattas WHERE regatta_id='385-2026-hyc-cape-classic';\""
expect {
    -re "assword" { send "$password\r"; exp_continue }
    eof { }
    timeout { puts "ERROR: timeout"; exit 1 }
}
wait

spawn ssh -o StrictHostKeyChecking=no ${user}@${server} "psql postgresql://sailors_user:SailSA_Pg_Beta2026!@localhost:5432/sailors_master -c \"UPDATE regattas SET start_date='2026-02-15', end_date='2026-02-16' WHERE regatta_id='385-2026-hyc-cape-classic';\""
expect {
    -re "assword" { send "$password\r"; exp_continue }
    eof { }
    timeout { puts "ERROR: timeout"; exit 1 }
}
wait

spawn ssh -o StrictHostKeyChecking=no ${user}@${server} "psql postgresql://sailors_user:SailSA_Pg_Beta2026!@localhost:5432/sailors_master -c \"SELECT regatta_id, start_date, end_date, as_at_time FROM regattas WHERE regatta_id='385-2026-hyc-cape-classic';\""
expect {
    -re "assword" { send "$password\r"; exp_continue }
    eof { }
    timeout { puts "ERROR: timeout"; exit 1 }
}
wait
