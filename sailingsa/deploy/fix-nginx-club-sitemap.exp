#!/usr/bin/expect -f
# SSH: show nginx config, add /club/ and /sitemap.xml if missing, reload, verify.
# Run from project root: expect sailingsa/deploy/fix-nginx-club-sitemap.exp

set timeout 60
set password "TimAdd#072082"
set server "102.218.215.253"
set user "root"

set script_dir [file dirname [info script]]
set sh_path "$script_dir/fix-nginx-club-sitemap.sh"

puts "=========================================="
puts "SailingSA — nginx /club/ and /sitemap.xml"
puts "=========================================="
puts ""

# Step 1: Show nginx config
puts "--- Step 1: Current nginx config ---"
spawn ssh -o StrictHostKeyChecking=no ${user}@${server} "cat /etc/nginx/sites-enabled/* 2>/dev/null"
expect {
    -re "assword|password" { send "$password\r"; exp_continue }
    eof { }
    timeout { puts "Timeout"; exit 1 }
}
wait

puts ""
puts "--- Step 2: Apply fix (add /club/, /sitemap.xml if missing) ---"
spawn scp -o StrictHostKeyChecking=no $sh_path ${user}@${server}:/tmp/fix-nginx-club-sitemap.sh
expect {
    -re "assword|password" { send "$password\r"; exp_continue }
    "100%" { }
    eof { }
    timeout { puts "Timeout"; exit 1 }
}
wait

spawn ssh -o StrictHostKeyChecking=no ${user}@${server} "chmod +x /tmp/fix-nginx-club-sitemap.sh && /tmp/fix-nginx-club-sitemap.sh"
expect {
    -re "assword|password" { send "$password\r"; exp_continue }
    "NGINX_RELOADED" { }
    "ERROR" { puts "Fix failed"; exit 1 }
    eof { }
    timeout { puts "Timeout"; exit 1 }
}
wait

puts ""
puts "--- Step 3: Verify curl ---"
spawn ssh -o StrictHostKeyChecking=no ${user}@${server} "echo '=== /club/hermanus-yacht-club ==='; curl -sI https://sailingsa.co.za/club/hermanus-yacht-club 2>/dev/null | head -3; echo ''; echo '=== /sitemap.xml ==='; curl -sI https://sailingsa.co.za/sitemap.xml 2>/dev/null | head -3"
expect {
    -re "assword|password" { send "$password\r"; exp_continue }
    eof { }
    timeout { puts "Timeout"; exit 1 }
}
wait

puts ""
puts "Done."
