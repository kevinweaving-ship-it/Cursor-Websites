#!/usr/bin/expect -f
# Safe UPDATE: set result_status and as_at_time for regatta 385 on LIVE DB only.
# Review sailingsa/deploy/update-live-regatta-385-snapshot.sql first. Then run:
#   From project root: expect sailingsa/deploy/update-live-regatta-385-snapshot.exp
# DO NOT run automatically — confirm then run manually.
set timeout 30
set password "TimAdd#072082"
set server "102.218.215.253"
set user "root"
set script_dir "sailingsa/deploy"
set sql_file "update-live-regatta-385-snapshot.sql"

# Upload SQL and run on server
spawn bash -c "scp -o StrictHostKeyChecking=no $script_dir/$sql_file ${user}@${server}:/tmp/ && ssh -o StrictHostKeyChecking=no ${user}@${server} \"psql postgresql://sailors_user:SailSA_Pg_Beta2026!@localhost:5432/sailors_master -f /tmp/$sql_file\""
expect {
    -re "assword" { send "$password\r"; exp_continue }
    -re "password" { send "$password\r"; exp_continue }
    eof { }
    timeout { puts "ERROR: timeout"; exit 1 }
}
wait
