#!/usr/bin/expect -f
# Full fix for live sailingsa.co.za. Runs on LIVE server only.
# Run from project root: expect sailingsa/deploy/fix-live-full.exp

set timeout 120
set password "TimAdd#072082"
set server "102.218.215.253"
set user "root"
set web_root "/var/www/sailingsa"
set api_root "/var/www/sailingsa/api"

puts "=========================================="
puts "FIX LIVE — sailingsa.co.za (102.218.215.253)"
puts "=========================================="
puts ""

# Single SSH: diagnose + fix (remote command in quotes so it runs on server)
set remote_cmd "echo '=== 1. API STATUS ===' && systemctl status sailingsa-api --no-pager 2>&1 | head -15; echo ''; echo '=== 2. JOURNAL ===' && journalctl -u sailingsa-api -n 25 --no-pager 2>&1; echo ''; echo '=== 3. FIX + RESTART ===' && (grep -q STATIC_DIR /etc/systemd/system/sailingsa-api.service 2>/dev/null || sed -i '/WorkingDirectory=/a Environment=\\\"STATIC_DIR=/var/www/sailingsa\\\"' /etc/systemd/system/sailingsa-api.service) && systemctl daemon-reload 2>/dev/null && systemctl restart sailingsa-api 2>/dev/null && sleep 4; echo ''; echo '=== 4. CURL ===' && (curl -s -o /dev/null -w 'HTTP %{http_code}' --connect-timeout 5 http://127.0.0.1:8000/api/site-stats 2>/dev/null || echo 'FAIL'); echo ''; echo '=== 5. NGINX ===' && nginx -t 2>&1 && systemctl reload nginx 2>&1; echo ''; echo DONE"
spawn ssh -o StrictHostKeyChecking=no -o ConnectTimeout=20 ${user}@${server} $remote_cmd
expect {
    -re "assword" { send "$password\r"; exp_continue }
    "DONE" { puts "\n=== Fix complete ===" }
    "Connection refused" { puts "\nERROR: SSH refused" }
    "timed out" { puts "\nERROR: SSH timeout - run from your machine" }
    eof { }
    timeout { puts "\nERROR: Timeout" }
}
wait

puts ""
puts "Test: https://sailingsa.co.za/"
puts ""
