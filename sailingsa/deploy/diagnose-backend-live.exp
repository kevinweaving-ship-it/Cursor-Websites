#!/usr/bin/expect -f
# Run backend diagnostic on LIVE: ports, process, api.py sha256, curl x2 (90s apart), find api.py
set timeout 120
set password "TimAdd#072082"
set server "102.218.215.253"
set user "root"

spawn ssh -o StrictHostKeyChecking=no ${user}@${server} "echo '=== LISTENING PORTS ===' && ss -ltnp | grep -E ':8000|:80|:443'; echo '=== RUNNING BACKEND PROCESSES ===' && ps -ef | grep -E 'gunicorn|uvicorn' | grep -v grep; echo '=== API FILE CHECK ===' && cd /var/www/sailingsa/api && pwd && ls -lah && sha256sum api.py && grep -n 'serve_regatta_standalone' api.py && grep -n 'datetime.now' api.py; echo '=== HTML FROM LOCALHOST (1) ===' && curl -s http://127.0.0.1:8000/regatta/hyc-cape-classic-2026 | grep -oE 'Results are \[^<\]+'; echo '=== WAIT 90s ===' && sleep 90; echo '=== HTML FROM LOCALHOST (2) ===' && curl -s http://127.0.0.1:8000/regatta/hyc-cape-classic-2026 | grep -oE 'Results are \[^<\]+'; echo '=== ALL api.py COPIES ===' && find /var/www -name api.py"
expect {
    "password:" { send "$password\r"; exp_continue }
    eof { }
    timeout { puts "ERROR: timeout"; exit 1 }
}
wait
