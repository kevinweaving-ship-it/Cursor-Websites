#!/usr/bin/expect -f
# TASK 2 — Upload clean dump and restore (Option A)
set timeout 300
set password "TimAdd#072082"
set server "102.218.215.253"
set user "root"
set script_dir [file dirname [info script]]
set project_root [file normalize "$script_dir/../.."]
set dump_path "$project_root/sailingsa_beta_dump_clean.sql"

if {![file exists $dump_path]} {
    puts "ERROR: Dump not found: $dump_path"
    puts "Run: pg_dump -U postgres --no-owner --no-acl sailors_master > sailingsa_beta_dump_clean.sql"
    exit 1
}

puts "Uploading dump..."
spawn scp -o StrictHostKeyChecking=no $dump_path ${user}@${server}:/root/
expect {
    "password:" { send "$password\r"; exp_continue }
    eof { }
    timeout { puts "ERROR: SCP timeout"; exit 1 }
}
wait

puts "Dropping and recreating DB, restoring..."
spawn ssh -o StrictHostKeyChecking=no ${user}@${server} "sudo -u postgres psql -c \"SELECT pg_terminate_backend(pid) FROM pg_stat_activity WHERE datname='sailors_master' AND pid <> pg_backend_pid();\" 2>/dev/null; sudo -u postgres psql -c 'DROP DATABASE IF EXISTS sailors_master;' -c 'CREATE DATABASE sailors_master OWNER sailors_user;' && psql postgresql://sailors_user:SailSA_Pg_Beta2026!@localhost:5432/sailors_master < /root/sailingsa_beta_dump_clean.sql 2>&1 | tail -30"
expect {
    "password:" { send "$password\r"; exp_continue }
    eof { }
    timeout { puts "ERROR: Restore timeout"; exit 1 }
}
wait

puts "Restarting API..."
spawn ssh -o StrictHostKeyChecking=no ${user}@${server} "systemctl restart sailingsa-api && sleep 3 && systemctl status sailingsa-api --no-pager | head -10"
expect {
    "password:" { send "$password\r"; exp_continue }
    eof { }
    timeout { puts "ERROR: timeout"; exit 1 }
}
wait
puts "Done."
