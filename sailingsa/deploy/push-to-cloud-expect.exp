#!/usr/bin/expect -f
# SailingSA Beta V1 — Deploy via expect (SSH key preferred; no password in script)
# Run from project root: expect sailingsa/deploy/push-to-cloud-expect.exp
# Prefer: bash sailingsa/deploy/deploy-with-key.sh (uses ~/.ssh/sailingsa_live_key)

set timeout 60
set ssh_key "$env(HOME)/.ssh/sailingsa_live_key"
set server "102.218.215.253"
set user "root"
set web_root "/var/www/sailingsa"
set api_root "/var/www/sailingsa/api"

# Project root = parent of sailingsa/
set script_dir [file dirname [info script]]
set project_root [file normalize "$script_dir/../.."]
set zip_path "$project_root/sailingsa-frontend.zip"
set api_py "$project_root/api.py"
set req_txt "$project_root/requirements.txt"

if {![file exists $zip_path]} {
    puts "ERROR: Zip not found: $zip_path"
    puts "Run: cd sailingsa/frontend && zip -r ../../sailingsa-frontend.zip . -x '*.DS_Store' -x '*.BU_*' -x '*.bak' -x '*.md'"
    exit 1
}

puts "=========================================="
puts "SailingSA Beta V1 — Push to Cloud (expect)"
puts "=========================================="
puts "Server: $user@$server"
puts "Web root: $web_root"
puts ""

# Step 1: SCP zip
puts "Step 1: Uploading zip..."
spawn scp -i $ssh_key -o StrictHostKeyChecking=no $zip_path ${user}@${server}:/tmp/sailingsa-frontend.zip
expect {
    "100%" { expect eof }
    eof { }
    timeout { puts "ERROR: SCP timeout"; exit 1 }
}
puts "  Uploaded"
puts ""

# Step 2: SSH — backup, extract, chown
puts "Step 2: Backup, extract, chown..."
spawn ssh -i $ssh_key -o StrictHostKeyChecking=no ${user}@${server} "if \[ -d $web_root \]; then B=\$(date +%Y%m%d); sudo cp -a $web_root ${web_root}.backup.\$B; fi; sudo mkdir -p $web_root; cd $web_root && unzip -o /tmp/sailingsa-frontend.zip && rm -f /tmp/sailingsa-frontend.zip && chown -R www-data:www-data $web_root 2>/dev/null; ls index.html robots.txt sitemap.xml"
expect {
    eof { }
    timeout { puts "ERROR: SSH timeout"; exit 1 }
}
wait
puts "  Done"
puts ""

# Step 2b: Deploy untracked regatta frontend files (not in zip) so live matches local
set regatta_results "$project_root/sailingsa/frontend/regatta/results.html"
set regatta_class_results "$project_root/sailingsa/frontend/regatta/class/class-results.html"
set regatta_podium "$project_root/sailingsa/frontend/regatta/class/podium/podium.html"
set regatta_viewer "$project_root/regatta_viewer.html"
if {[file exists $regatta_results] && [file exists $regatta_class_results] && [file exists $regatta_podium] && [file exists $regatta_viewer]} {
    puts "Step 2b: Deploying regatta frontend (results, class-results, podium, regatta_viewer)..."
    spawn ssh -i $ssh_key -o StrictHostKeyChecking=no ${user}@${server} "mkdir -p $web_root/regatta/class/podium"
    expect {
        eof { }
        timeout { puts "ERROR: SSH mkdir regatta timeout"; exit 1 }
    }
    wait
    spawn scp -i $ssh_key -o StrictHostKeyChecking=no $regatta_results ${user}@${server}:${web_root}/regatta/results.html
    expect { "100%" { expect eof } eof { } timeout { puts "ERROR: SCP regatta timeout"; exit 1 } }
    wait
    spawn scp -i $ssh_key -o StrictHostKeyChecking=no $regatta_class_results ${user}@${server}:${web_root}/regatta/class/class-results.html
    expect { "100%" { expect eof } eof { } timeout { puts "ERROR: SCP regatta timeout"; exit 1 } }
    wait
    spawn scp -i $ssh_key -o StrictHostKeyChecking=no $regatta_podium ${user}@${server}:${web_root}/regatta/class/podium/podium.html
    expect { "100%" { expect eof } eof { } timeout { puts "ERROR: SCP regatta timeout"; exit 1 } }
    wait
    spawn scp -i $ssh_key -o StrictHostKeyChecking=no $regatta_viewer ${user}@${server}:${web_root}/regatta_viewer.html
    expect { "100%" { expect eof } eof { } timeout { puts "ERROR: SCP regatta_viewer timeout"; exit 1 } }
    wait
    spawn ssh -i $ssh_key -o StrictHostKeyChecking=no ${user}@${server} "chown -R www-data:www-data $web_root/regatta $web_root/regatta_viewer.html 2>/dev/null; echo OK"
    expect { "OK" { } eof { } timeout { puts "WARN: chown regatta timeout" } }
    wait
    puts "  Regatta frontend deployed"
} else {
    puts "Step 2b: Skipping regatta frontend (one or more of results.html, class-results.html, podium.html, regatta_viewer.html not found)"
}
puts ""

# Step 3: Deploy API (api.py + requirements.txt) so /api/site-stats fetches from DB
if {[file exists $api_py] && [file exists $req_txt]} {
    puts "Step 3: Deploying API (api.py, requirements.txt)..."
    spawn ssh -i $ssh_key -o StrictHostKeyChecking=no ${user}@${server} "mkdir -p $api_root"
    expect {
        eof { }
        timeout { puts "ERROR: SSH mkdir timeout"; exit 1 }
    }
    wait
    spawn scp -i $ssh_key -o StrictHostKeyChecking=no $api_py $req_txt ${user}@${server}:${api_root}/
    expect {
        "100%" { expect eof }
        eof { }
        timeout { puts "ERROR: SCP api timeout"; exit 1 }
    }
    wait
    puts "  Uploaded"
    puts "Step 4: STATIC_DIR, deps, restart API..."
    spawn ssh -i $ssh_key -o StrictHostKeyChecking=no ${user}@${server} "grep -q STATIC_DIR /etc/systemd/system/sailingsa-api.service 2>/dev/null || sed -i '/WorkingDirectory=/a Environment=\"STATIC_DIR=$web_root\"' /etc/systemd/system/sailingsa-api.service; systemctl daemon-reload 2>/dev/null; cd $api_root && (test -d venv && venv/bin/pip install -r requirements.txt -q || true) && systemctl restart sailingsa-api 2>/dev/null || systemctl restart sailingsa-api.service 2>/dev/null || true; echo OK"
    expect {
        "OK" { }
        eof { }
        timeout { puts "ERROR: SSH api timeout"; exit 1 }
    }
    wait
    puts "  API restarted"
    puts ""
} else {
    puts "Step 3: Skipping API deploy (api.py or requirements.txt not found at project root)"
    puts ""
}

# Step 5: Nginx /about (so /about serves about.html, not SPA fallback)
set fix_script "$script_dir/fix-nginx-about.sh"
if {[file exists $fix_script]} {
    puts "Step 5: Applying nginx /about fix..."
    spawn scp -i $ssh_key -o StrictHostKeyChecking=no $fix_script ${user}@${server}:/tmp/fix-nginx-about.sh
    expect {
        "100%" { expect eof }
        eof { }
        timeout { puts "WARN: SCP fix script timeout" }
    }
    wait
    spawn ssh -i $ssh_key -o StrictHostKeyChecking=no ${user}@${server} "bash /tmp/fix-nginx-about.sh"
    expect {
        "NGINX_RELOADED" { }
        "already present" { }
        eof { }
        timeout { puts "WARN: nginx fix timeout" }
    }
    wait
    puts "  Nginx /about fix applied"
} else {
    puts "Step 5: Skipping nginx fix (fix-nginx-about.sh not found)"
}

puts ""
puts "=========================================="
puts "Deploy complete (frontend + API)."
puts "=========================================="
puts ""
puts "Verify: https://sailingsa.co.za/about"
puts ""
