#!/usr/bin/expect -f
# Apply nginx redirect: /sailingsa/frontend/* -> /* (mobile login fix)
# Run from project root: expect sailingsa/deploy/apply-nginx-legacy-redirect.exp

set timeout 30
set password "TimAdd#072082"
set server "102.218.215.253"
set user "root"

set script_dir [file dirname [info script]]
set sh_path "$script_dir/add-nginx-legacy-redirect.sh"

if {![file exists $sh_path]} {
    puts "ERROR: $sh_path not found"
    exit 1
}

puts "=========================================="
puts "Apply nginx legacy redirect (mobile login)"
puts "=========================================="
puts "Server: $user@$server"
puts ""

# Upload script
puts "Uploading add-nginx-legacy-redirect.sh..."
spawn scp -o StrictHostKeyChecking=no $sh_path ${user}@${server}:/tmp/add-nginx-legacy-redirect.sh
expect {
    "password:" { send "$password\r"; exp_continue }
    eof { }
    timeout { puts "ERROR: SCP timeout"; exit 1 }
}
wait
puts "  Uploaded"
puts ""

# Run on server
puts "Running on server..."
spawn ssh -o StrictHostKeyChecking=no ${user}@${server} "chmod +x /tmp/add-nginx-legacy-redirect.sh && /tmp/add-nginx-legacy-redirect.sh"
expect {
    "password:" { send "$password\r"; exp_continue }
    eof { }
    timeout { puts "ERROR: SSH timeout"; exit 1 }
}
wait
puts ""
puts "Done. Test mobile: https://sailingsa.co.za/sailingsa/frontend/login.html should redirect to https://sailingsa.co.za/login.html"
