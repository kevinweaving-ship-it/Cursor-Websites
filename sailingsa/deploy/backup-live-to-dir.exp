#!/usr/bin/expect -f
# Backup live api.py + frontend files to dest_dir. Usage: expect sailingsa/deploy/backup-live-to-dir.exp /path/to/dest
set timeout 60
set password "TimAdd#072082"
set server "102.218.215.253"
set user "root"
set web_root "/var/www/sailingsa"
set api_root "/var/www/sailingsa/api"
set dest_dir [lindex $argv 0]
if {$dest_dir == ""} { puts "Usage: expect backup-live-to-dir.exp <dest_dir>"; exit 1 }
file mkdir $dest_dir
file mkdir $dest_dir/sailingsa/frontend/regatta/class
puts "Backing up LIVE to: $dest_dir"
spawn scp -o StrictHostKeyChecking=no ${user}@${server}:${api_root}/api.py $dest_dir/
expect { -re "assword" { send "$password\r"; exp_continue } eof { } timeout { exit 1 } }
wait
spawn scp -o StrictHostKeyChecking=no ${user}@${server}:${web_root}/index.html $dest_dir/sailingsa/frontend/
expect { -re "assword" { send "$password\r"; exp_continue } eof { } timeout { exit 1 } }
wait
spawn scp -o StrictHostKeyChecking=no ${user}@${server}:${web_root}/regatta/results.html $dest_dir/sailingsa/frontend/regatta/
expect { -re "assword" { send "$password\r"; exp_continue } eof { } timeout { exit 1 } }
wait
spawn scp -o StrictHostKeyChecking=no ${user}@${server}:${web_root}/regatta/class/class-results.html $dest_dir/sailingsa/frontend/regatta/class/
expect { -re "assword" { send "$password\r"; exp_continue } eof { } timeout { exit 1 } }
wait
puts "Done."
exit 0
