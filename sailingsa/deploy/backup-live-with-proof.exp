#!/usr/bin/expect -f
# Backup live sailors_master DB and write proof. Run from project root.
set timeout 180
set password "TimAdd#072082"
set server "102.218.215.253"
set user "root"
set dburl "postgresql://sailors_user:SailSA_Pg_Beta2026@localhost:5432/sailors_master"
set script_dir [file dirname [info script]]
set project_root [file normalize "$script_dir/../.."]
set stamp [clock format [clock seconds] -format %Y%m%d_%H%M%S]
set backups "$project_root/backups"
set remote_dump "/tmp/sailors_master_live_$stamp.sql"
set remote_proof "/tmp/PROOF_live_$stamp.txt"
set local_dump "$backups/live_sailors_master_$stamp.sql"
set local_proof "$backups/PROOF_live_$stamp.txt"

exec mkdir -p $backups

puts "=== Live backup (pg_dump on server) ==="
spawn ssh -o StrictHostKeyChecking=no ${user}@${server} "pg_dump $dburl --no-owner --no-acl -f $remote_dump && echo DONE"
expect {
    -re "assword" { send "$password\r"; exp_continue }
    "DONE" { }
    eof { }
    timeout { puts "ERROR: timeout"; exit 1 }
}
wait

puts "=== Proof on server ==="
spawn ssh -o StrictHostKeyChecking=no ${user}@${server} "echo \"Backup: live_sailors_master_$stamp.sql\" > $remote_proof; echo \"At: $stamp\" >> $remote_proof; echo '--- result_id 4563 ---' >> $remote_proof; psql $dburl -t -A -c \"SELECT result_id, helm_name, helm_sa_sailing_id, fleet_label, class_canonical FROM results WHERE result_id = 4563;\" >> $remote_proof; echo '' >> $remote_proof; echo '--- regatta 385 result count ---' >> $remote_proof; psql $dburl -t -A -c \"SELECT COUNT(*) FROM results WHERE regatta_id = '385-2026-hyc-cape-classic';\" >> $remote_proof; echo DONE"
expect {
    -re "assword" { send "$password\r"; exp_continue }
    "DONE" { }
    eof { }
    timeout { puts "ERROR: timeout"; exit 1 }
}
wait

puts "=== Download dump and proof to local ==="
spawn scp -o StrictHostKeyChecking=no ${user}@${server}:${remote_dump} $local_dump
expect {
    -re "assword" { send "$password\r"; exp_continue }
    "100%" { expect eof }
    eof { }
    timeout { puts "ERROR: timeout"; exit 1 }
}
wait

spawn scp -o StrictHostKeyChecking=no ${user}@${server}:${remote_proof} $local_proof
expect {
    -re "assword" { send "$password\r"; exp_continue }
    "100%" { expect eof }
    eof { }
    timeout { puts "ERROR: timeout"; exit 1 }
}
wait

spawn ssh -o StrictHostKeyChecking=no ${user}@${server} "rm -f $remote_dump $remote_proof"
expect {
    -re "assword" { send "$password\r"; exp_continue }
    eof { }
}
wait

puts ""
puts "Done. Live dump: $local_dump"
puts "Proof: $local_proof"
