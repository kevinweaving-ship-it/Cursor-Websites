#!/usr/bin/expect -f
# Read-only: fetch live index.html sections for comparison. Uses same auth as SSH_LIVE.md / push-to-cloud.
# Run from project root: expect sailingsa/deploy/read-live-index.exp

set timeout 30
set password "TimAdd#072082"
set server "102.218.215.253"
set user "root"
set web_root "/var/www/sailingsa"

# Output both sections: CSS .regatta-result-sheet-modal (902-915), JS openResultPageInModal (4536-4562)
spawn ssh -o StrictHostKeyChecking=no ${user}@${server} "echo '=== LIVE CSS .regatta-result-sheet-modal (902-915) ===' && sed -n '902,915p' $web_root/index.html && echo '' && echo '=== LIVE JS openResultPageInModal (4536-4562) ===' && sed -n '4536,4562p' $web_root/index.html"
expect {
    "password:" { send "$password\r"; exp_continue }
    eof { }
    timeout { puts "ERROR: timeout"; exit 1 }
}
wait
