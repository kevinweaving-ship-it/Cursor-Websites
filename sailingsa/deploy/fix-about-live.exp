#!/usr/bin/expect -f
# One-off: Fix About popup/redirect on live. Adds STATIC_DIR + nginx /about.
# Run: expect sailingsa/deploy/fix-about-live.exp

set timeout 30
set password "TimAdd#072082"
set server "102.218.215.253"
set user "root"
set web_root "/var/www/sailingsa"
set script_dir [file dirname [info script]]
set fix_script "$script_dir/fix-nginx-about.sh"

puts "Fix About on live: STATIC_DIR + nginx /about"
puts ""

# 1. STATIC_DIR in sailingsa-api.service
puts "1. Adding STATIC_DIR to sailingsa-api..."
spawn ssh -o StrictHostKeyChecking=no ${user}@${server} "grep -q STATIC_DIR /etc/systemd/system/sailingsa-api.service 2>/dev/null || sed -i '/WorkingDirectory=/a Environment=\"STATIC_DIR=$web_root\"' /etc/systemd/system/sailingsa-api.service; systemctl daemon-reload && systemctl restart sailingsa-api && sleep 2 && systemctl is-active sailingsa-api"
expect {
    "password:" { send "$password\r"; exp_continue }
    "active" { }
    eof { }
    timeout { puts "WARN: timeout" }
}
wait

# 2. Nginx /about
puts ""
puts "2. Applying nginx /about fix..."
spawn scp -o StrictHostKeyChecking=no $fix_script ${user}@${server}:/tmp/fix-nginx-about.sh
expect {
    "password:" { send "$password\r"; exp_continue }
    "100%" { expect eof }
    eof { }
}
wait

spawn ssh -o StrictHostKeyChecking=no ${user}@${server} "bash /tmp/fix-nginx-about.sh"
expect {
    "password:" { send "$password\r"; exp_continue }
    "NGINX_RELOADED" { }
    "already present" { }
    eof { }
}
wait

puts ""
puts "Done. Test: https://sailingsa.co.za/about"
