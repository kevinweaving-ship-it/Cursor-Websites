#!/usr/bin/expect -f
# Apply patch: Sail 1311 Optimist B = Mason Guthrie (remove Gordon 5820). Run from project root.
set timeout 60
set password "TimAdd#072082"
set server "102.218.215.253"
set user "root"
set script_dir [file dirname [info script]]
set project_root [file normalize "$script_dir/../.."]
set sql_path "$project_root/sailingsa/deploy/patch_4563_mason_optimist_b.sql"

if {![file exists $sql_path]} {
    puts "ERROR: patch_4563_mason_optimist_b.sql not found."
    exit 1
}

puts "=== Uploading patch_4563_mason_optimist_b.sql to live ==="
spawn scp -o StrictHostKeyChecking=no $sql_path ${user}@${server}:/tmp/
expect {
    -re "assword" { send "$password\r"; exp_continue }
    "100%" { expect eof }
    eof { }
    timeout { puts "ERROR: timeout"; exit 1 }
}
wait

puts "=== Applying patch on live DB ==="
spawn ssh -o StrictHostKeyChecking=no ${user}@${server} "psql postgresql://sailors_user:SailSA_Pg_Beta2026@localhost:5432/sailors_master -f /tmp/patch_4563_mason_optimist_b.sql 2>&1"
expect {
    -re "assword" { send "$password\r"; exp_continue }
    "UPDATE 1" { }
    "UPDATE 0" { }
    eof { }
    timeout { puts "ERROR: timeout"; exit 1 }
}
wait

puts "=== Restart API ==="
spawn ssh -o StrictHostKeyChecking=no ${user}@${server} "systemctl restart sailingsa-api && echo Done"
expect {
    -re "assword" { send "$password\r"; exp_continue }
    "Done" { }
    eof { }
    timeout { puts "ERROR: timeout"; exit 1 }
}
wait

puts ""
puts "Done. Gordon Guthrie must no longer show Sail No 1311. Verify: https://sailingsa.co.za/sailor/gordon-guthrie-5820"
