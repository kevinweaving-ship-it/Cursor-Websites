#!/usr/bin/expect -f
# Execute: legacy path kill, nginx fix, re-extract, restart, verification
# Run from project root: expect sailingsa/deploy/apply-nginx-and-legacy-fix.exp

set timeout 120
set password "TimAdd#072082"
set server "102.218.215.253"
set user "root"
set web_root "/var/www/sailingsa"
set script_dir [file dirname [info script]]
set project_root [file normalize "$script_dir/../.."]

# Ensure frontend zip exists
if {![file exists "$project_root/sailingsa-frontend.zip"]} {
    puts "Building sailingsa-frontend.zip..."
    spawn sh -c "cd $project_root/sailingsa/frontend && zip -r $project_root/sailingsa-frontend.zip . -x '*.DS_Store' -x '__MACOSX' -x '*.BU_*' -x '*.bak'"
    expect eof
    wait
}

puts "=== Upload zip + script ==="
spawn scp -o StrictHostKeyChecking=no \
    $project_root/sailingsa-frontend.zip \
    $script_dir/apply-nginx-and-legacy-fix.sh \
    ${user}@${server}:/tmp/
expect { "password:" { send "$password\r"; exp_continue } eof { } timeout { exit 1 } }
wait

puts "\n=== Run apply script on server ==="
spawn ssh -o StrictHostKeyChecking=no ${user}@${server} "chmod +x /tmp/apply-nginx-and-legacy-fix.sh && /tmp/apply-nginx-and-legacy-fix.sh"
expect { "password:" { send "$password\r"; exp_continue } eof { } timeout { exit 1 } }
wait

puts "\n=== Local verification curls ==="
spawn sh -c {
    echo "Legacy (must 404):"
    curl -sI -o /dev/null -w "  /sailingsa/frontend/login.html  %{http_code}\n" https://sailingsa.co.za/sailingsa/frontend/login.html
    curl -sI -o /dev/null -w "  /sailingsa/frontend/index.html  %{http_code}\n" https://sailingsa.co.za/sailingsa/frontend/index.html
    echo "Root (must 200):"
    curl -sI -o /dev/null -w "  /login.html  %{http_code}\n" https://sailingsa.co.za/login.html
    curl -sI -o /dev/null -w "  /index.html  %{http_code}\n" https://sailingsa.co.za/index.html
    echo "Auth POST (200 or 401, not 405):"
    curl -sI -o /dev/null -w "  /auth/login POST  %{http_code}\n" -X POST https://sailingsa.co.za/auth/login -H "Content-Type: application/json" -d '{"provider":"username","username":"21172","password":"test"}'
}
expect eof
wait

puts "\n=== DONE ==="
