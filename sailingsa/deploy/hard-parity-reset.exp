#!/usr/bin/expect -f
# HARD PARITY RESET — Mac canonical, cloud must match
# Run from project root: expect sailingsa/deploy/hard-parity-reset.exp

set timeout 180
set password "TimAdd#072082"
set server "102.218.215.253"
set user "root"
set api_dir "/var/www/sailingsa/api"
set script_dir [file dirname [info script]]
set project_root [file normalize "$script_dir/../.."]

puts "=== STEP 1 — Kill any wrong API ==="
spawn ssh -o StrictHostKeyChecking=no ${user}@${server} "systemctl stop sailingsa-api 2>/dev/null; pkill -f uvicorn 2>/dev/null; sleep 2; echo done"
expect { "password:" { send "$password\r"; exp_continue } eof { } timeout { exit 1 } }
wait

puts "\n=== STEP 2 — Ensure api dir exists, upload api.py (overwrite) ==="
spawn ssh -o StrictHostKeyChecking=no ${user}@${server} "mkdir -p ${api_dir}"
expect { "password:" { send "$password\r"; exp_continue } eof { } timeout { exit 1 } }
wait
spawn scp -o StrictHostKeyChecking=no $project_root/api.py ${user}@${server}:${api_dir}/api.py
expect { "password:" { send "$password\r"; exp_continue } eof { } timeout { exit 1 } }
wait

puts "\n=== STEP 3 — Upload and run hard-parity-reset.sh ==="
spawn scp -o StrictHostKeyChecking=no $script_dir/hard-parity-reset.sh ${user}@${server}:/tmp/
expect { "password:" { send "$password\r"; exp_continue } eof { } timeout { exit 1 } }
wait

spawn ssh -o StrictHostKeyChecking=no ${user}@${server} "chmod +x /tmp/hard-parity-reset.sh && /tmp/hard-parity-reset.sh"
expect { "password:" { send "$password\r"; exp_continue } eof { } timeout { exit 1 } }
wait

puts "\n=== DONE ==="
