#!/usr/bin/expect -f
# Backup live frontend pages to local. Uses ssh+tar for one password.
# Run from project root: expect sailingsa/deploy/backup-live-pages.exp

set timeout 60
set password "TimAdd#072082"
set server "102.218.215.253"
set user "root"
set script_dir [file dirname [info script]]
set project_root [file normalize "$script_dir/../.."]
set ts [clock format [clock seconds] -format %Y%m%d_%H%M%S]
set dest_dir "$project_root/BACKUP_LIVE_$ts"
file mkdir $dest_dir
puts "Backing up live pages to: $dest_dir"
set tmp_script "/tmp/backup_live_$ts.sh"
set f [open $tmp_script w]
puts $f "#!/bin/bash"
puts $f "ssh -o StrictHostKeyChecking=no ${user}@${server} 'cd /var/www/sailingsa && tar cf - index.html about.html site-stats.html css/main.css' | tar -C \"$dest_dir\" -xf -"
close $f
exec chmod +x $tmp_script
spawn bash $tmp_script
expect "password:"
send "$password\r"
expect eof
wait
puts "Done. Files in: $dest_dir"
