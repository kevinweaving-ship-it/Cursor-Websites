#!/usr/bin/expect -f
set timeout 30
set password "TimAdd#072082"
set server "102.218.215.253"
set user "root"

# Find sailingsa nginx config and add robots/sitemap blocks before "location /"
set nginx_insert {
    location = /robots.txt {
        default_type text/plain;
        try_files \$uri =404;
    }
    location = /sitemap.xml {
        default_type application/xml;
        try_files \$uri =404;
    }
}

# List nginx configs to find sailingsa
spawn ssh -o StrictHostKeyChecking=no ${user}@${server} "ls -la /etc/nginx/sites-available/ | grep -E 'sailing|default'"
expect {
    "password:" { send "$password\r"; exp_continue }
    eof { }
    timeout { exit 1 }
}
wait
