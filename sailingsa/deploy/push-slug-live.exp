#!/usr/bin/expect -f
# Deploy slug/redirect to live: frontend + backend (api.py with STATIC_DIR), with backups.
# Run from project root: expect sailingsa/deploy/push-slug-live.exp

set timeout 120
set password "TimAdd#072082"
set server "102.218.215.253"
set user "root"
set web_root "/var/www/sailingsa"
set api_dir "/var/www/sailingsa/api"

set script_dir [file dirname [info script]]
set project_root [file normalize "$script_dir/../.."]
set zip_path "$project_root/sailingsa-frontend.zip"
set api_py "$project_root/api.py"

if {![file exists $zip_path]} {
    puts "Building sailingsa-frontend.zip..."
    spawn sh -c "cd $project_root/sailingsa/frontend && zip -r $zip_path . -x '*.DS_Store' -x '__MACOSX' -x '*.BU_*' -x '*.bu_*' -x '*.bak' -x '*.md'"
    expect eof
    wait
}
if {![file exists $api_py]} {
    puts "ERROR: api.py not found: $api_py"
    exit 1
}

puts "=========================================="
puts "SailingSA — Deploy slug/redirect to live"
puts "=========================================="
puts "Server: $user@$server"
puts "Web root: $web_root  API: $api_dir"
puts ""

puts "Step 1: Upload frontend zip..."
spawn scp -o StrictHostKeyChecking=no $zip_path ${user}@${server}:/tmp/sailingsa-frontend.zip
expect { -re "password|Password" { send "$password\r"; exp_continue } "100%" { expect eof } eof { } timeout { puts "ERROR: SCP timeout"; exit 1 } }
wait
puts "  Done"

puts "Step 2: On server — backup web root and api.py..."
spawn ssh -o StrictHostKeyChecking=no ${user}@${server} "B=\$(date +%Y%m%d_%H%M%S); sudo cp -a $web_root ${web_root}.backup.\$B 2>/dev/null && echo WebBackup: ${web_root}.backup.\$B; cp ${api_dir}/api.py ${api_dir}/api.py.backup.\$B 2>/dev/null && echo ApiBackup: api.py.backup.\$B"
expect { -re "password|Password" { send "$password\r"; exp_continue } eof { } timeout { exit 1 } }
wait
puts "  Done"

puts "Step 3: Upload api.py..."
spawn scp -o StrictHostKeyChecking=no $api_py ${user}@${server}:${api_dir}/api.py
expect { -re "password|Password" { send "$password\r"; exp_continue } eof { } timeout { exit 1 } }
wait
puts "  Done"

puts "Step 4: On server — extract frontend, chown..."
spawn ssh -o StrictHostKeyChecking=no ${user}@${server} "cd $web_root && unzip -o /tmp/sailingsa-frontend.zip && rm -f /tmp/sailingsa-frontend.zip && chown -R www-data:www-data $web_root 2>/dev/null; ls -la index.html 2>/dev/null"
expect { -re "password|Password" { send "$password\r"; exp_continue } eof { } timeout { exit 1 } }
wait
puts "  Done"

puts "Step 5: On server — STATIC_DIR, restart sailingsa-api..."
spawn ssh -o StrictHostKeyChecking=no ${user}@${server} "grep -q STATIC_DIR /etc/systemd/system/sailingsa-api.service || sed -i '/WorkingDirectory=/a Environment=\"STATIC_DIR=/var/www/sailingsa\"' /etc/systemd/system/sailingsa-api.service; systemctl daemon-reload && systemctl restart sailingsa-api && sleep 2 && systemctl status sailingsa-api --no-pager | head -10"
expect { -re "password|Password" { send "$password\r"; exp_continue } eof { } timeout { exit 1 } }
wait
puts "  Done"

puts ""
puts "=========================================="
puts "Deploy complete. REQUIRED: Nginx must proxy /, /index.html, /sailor/ to API."
puts "See: sailingsa/deploy/nginx-slug-routes.conf and DEPLOY_SLUG_COMMANDS.md"
puts "Then: ssh root@$server 'nginx -t && systemctl reload nginx'"
puts "Verify: curl -sI 'https://sailingsa.co.za/index.html?sas_id=18020' => 301 to /sailor/..."
puts "=========================================="
