#!/usr/bin/expect -f
# Rollback api.py to known-good backup (use if API crashes on startup).
# Run from project root: expect sailingsa/deploy/fix-live-rollback-api.exp

set timeout 90
set password "TimAdd#072082"
set server "102.218.215.253"
set user "root"
set api_root "/var/www/sailingsa/api"

set project_root [file normalize "[file dirname [info script]]/../.."]
set backup_api "$project_root/api.py.BU_20260213_120511"

if {![file exists $backup_api]} {
    puts "ERROR: Backup not found: $backup_api"
    exit 1
}

puts "=========================================="
puts "Rollback API — Deploy api.py.BU_20260213"
puts "=========================================="

spawn scp -o StrictHostKeyChecking=no $backup_api ${user}@${server}:${api_root}/api.py
expect {
    -re "assword" { send "$password\r"; exp_continue }
    "100%" { }
    eof { }
    timeout { puts "SCP timeout"; exit 1 }
}
wait

spawn ssh -o StrictHostKeyChecking=no ${user}@${server} "systemctl restart sailingsa-api && sleep 3 && systemctl status sailingsa-api --no-pager | head -12"
expect {
    -re "assword" { send "$password\r"; exp_continue }
    eof { }
    timeout { }
}
wait

puts ""
puts "Done. Test: https://sailingsa.co.za/"
