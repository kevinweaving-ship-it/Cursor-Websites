#!/usr/bin/expect -f
# Run insert_genmac_dabchick_1_8.py on live server (uses server's DB).
# Run from project root: expect sailingsa/deploy/run-insert-genmac-dabchick.exp

set timeout 90
set password "TimAdd#072082"
set server "102.218.215.253"
set user "root"

set project_root [file normalize "[file dirname [info script]]/../.."]
set script "$project_root/insert_genmac_dabchick_1_8.py"

if {![file exists $script]} {
    puts "ERROR: $script not found"
    exit 1
}

puts "Uploading and running insert_genmac_dabchick_1_8.py on server..."
spawn scp -o StrictHostKeyChecking=no $script ${user}@${server}:/tmp/
expect {
    -re "assword|password" { send "$password\r"; exp_continue }
    "100%" { }
    eof { }
    timeout { puts "Timeout"; exit 1 }
}
wait

spawn ssh -o StrictHostKeyChecking=no ${user}@${server} "DB_URL=postgresql://sailors_user:SailSA_Pg_Beta2026!@localhost:5432/sailors_master /var/www/sailingsa/api/venv/bin/python3 /tmp/insert_genmac_dabchick_1_8.py 2>&1 || echo 'Insert failed'"
expect {
    -re "assword|password" { send "$password\r"; exp_continue }
    "Inserted" { }
    "Check DB_URL" { }
    eof { }
    timeout { puts "Timeout"; exit 1 }
}
wait
puts ""
puts "Verify: curl -s https://sailingsa.co.za/regatta/genmac-sa-sailing-youth-nationals | grep -o Sean"
