#!/usr/bin/expect -f
# Run fix_all_clubs_host_regattas.py on live server. DB_URL must be set in api env.
# Run from project root: expect sailingsa/deploy/run-db-fixes-on-live.exp

set timeout 60
set password "TimAdd#072082"
set server "102.218.215.253"
set user "root"

set project_root [file normalize "[file dirname [info script]]/../.."]
set script1 "$project_root/fix_all_clubs_host_regattas.py"

if {![file exists $script1]} {
    puts "ERROR: fix_all_clubs_host_regattas.py not found"
    exit 1
}

puts "Uploading and running DB fix on live..."
spawn scp -o StrictHostKeyChecking=no $script1 ${user}@${server}:/var/www/sailingsa/api/fix_all_clubs_host_regattas.py
expect {
    -re "assword|password" { send "$password\r"; exp_continue }
    "100%" { }
    eof { }
    timeout { puts "Timeout"; exit 1 }
}
wait

spawn ssh -o StrictHostKeyChecking=no ${user}@${server} "cd /var/www/sailingsa/api && export \$(systemctl show sailingsa-api -p Environment --value 2>/dev/null | tr ' ' '\\n' | grep '=' | xargs) 2>/dev/null; python3 fix_all_clubs_host_regattas.py 2>&1"
expect {
    -re "assword|password" { send "$password\r"; exp_continue }
    eof { }
    timeout { puts "Timeout"; exit 1 }
}
wait

puts ""
puts "Done. If DB_URL is not set on server, run manually with: DB_URL=<live-connection-string> python3 fix_all_clubs_host_regattas.py"
