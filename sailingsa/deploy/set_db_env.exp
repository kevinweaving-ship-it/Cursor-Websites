#!/usr/bin/expect -f
set timeout 20
set password "TimAdd#072082"
set dburl "postgresql://sailors_user:SailSA_Pg_Beta2026!@localhost:5432/sailors_master"

# Add Environment line after WorkingDirectory in sailingsa-api.service
spawn ssh -o StrictHostKeyChecking=no root@102.218.215.253 "grep -q 'DATABASE_URL' /etc/systemd/system/sailingsa-api.service || (sed -i '/WorkingDirectory=/a Environment=\"DATABASE_URL=$dburl\"' /etc/systemd/system/sailingsa-api.service); systemctl daemon-reload; systemctl restart sailingsa-api; sleep 2; systemctl status sailingsa-api --no-pager | head -8"
expect "password:"
send "$password\r"
expect eof
wait
