#!/usr/bin/expect -f
# STEP 2: HYC 385 three queries. STEP 3: same three for one regatta with as_at_time NOT NULL.
set timeout 45
set password "TimAdd#072082"
set server "102.218.215.253"
set user "root"

spawn ssh -o StrictHostKeyChecking=no ${user}@${server} "echo '=== HYC 385 regattas row ===' && psql postgresql://sailors_user:SailSA_Pg_Beta2026!@localhost:5432/sailors_master -c \"SELECT regatta_id, result_status, as_at_time, start_date, end_date FROM regattas WHERE regatta_id = '385-2026-hyc-cape-classic';\" && echo '=== HYC 385 DISTINCT as_at_time from results ===' && psql postgresql://sailors_user:SailSA_Pg_Beta2026!@localhost:5432/sailors_master -c \"SELECT DISTINCT as_at_time FROM results WHERE regatta_id = '385-2026-hyc-cape-classic';\" && echo '=== HYC 385 COUNT results with as_at_time IS NULL ===' && psql postgresql://sailors_user:SailSA_Pg_Beta2026!@localhost:5432/sailors_master -c \"SELECT COUNT(*) FROM results WHERE regatta_id = '385-2026-hyc-cape-classic' AND as_at_time IS NULL;\" && echo '=== KNOWN GOOD (first regatta with as_at_time NOT NULL) ===' && GOOD=\$(psql postgresql://sailors_user:SailSA_Pg_Beta2026!@localhost:5432/sailors_master -t -A -c \"SELECT regatta_id FROM regattas WHERE as_at_time IS NOT NULL LIMIT 1;\") && echo \"Regatta: \$GOOD\" && psql postgresql://sailors_user:SailSA_Pg_Beta2026!@localhost:5432/sailors_master -c \"SELECT regatta_id, result_status, as_at_time, start_date, end_date FROM regattas WHERE regatta_id = '\$GOOD';\" && psql postgresql://sailors_user:SailSA_Pg_Beta2026!@localhost:5432/sailors_master -c \"SELECT DISTINCT as_at_time FROM results WHERE regatta_id = '\$GOOD';\" && psql postgresql://sailors_user:SailSA_Pg_Beta2026!@localhost:5432/sailors_master -c \"SELECT COUNT(*) FROM results WHERE regatta_id = '\$GOOD' AND as_at_time IS NULL;\""
expect {
    -re "assword" { send "$password\r"; exp_continue }
    eof { }
    timeout { puts "ERROR: timeout"; exit 1 }
}
wait
