#!/usr/bin/expect -f
# Fix live API timeouts: restart sailingsa-api, ensure STATIC_DIR, reload nginx.
# Run from project root: expect sailingsa/deploy/fix-live-now.exp

set timeout 90
set password "TimAdd#072082"
set server "102.218.215.253"
set user "root"
set web_root "/var/www/sailingsa"
set api_root "/var/www/sailingsa/api"

puts "=========================================="
puts "Fix Live — Restart API + Nginx"
puts "=========================================="
puts "Server: $user@$server"
puts ""

# Step 1: Ensure STATIC_DIR, restart sailingsa-api
puts "Step 1: Restart sailingsa-api..."
spawn ssh -o StrictHostKeyChecking=no ${user}@${server} "grep -q STATIC_DIR /etc/systemd/system/sailingsa-api.service 2>/dev/null || sed -i '/WorkingDirectory=/a Environment=\"STATIC_DIR=$web_root\"' /etc/systemd/system/sailingsa-api.service; systemctl daemon-reload 2>/dev/null; systemctl restart sailingsa-api 2>/dev/null || systemctl restart sailingsa-api.service 2>/dev/null; sleep 3; systemctl status sailingsa-api --no-pager | head -15"
expect {
    -re "assword" { send "$password\r"; exp_continue }
    "active (running)" { }
    "Active: active" { }
    "failed" { puts "\nWARN: sailingsa-api may have failed. Check journalctl." }
    eof { }
    timeout { puts "WARN: Timeout" }
}
wait
puts ""

# Step 2: Test API locally on server
puts "Step 2: Test API (curl 127.0.0.1:8000)..."
spawn ssh -o StrictHostKeyChecking=no ${user}@${server} "curl -s -o /dev/null -w 'HTTP %{http_code}' http://127.0.0.1:8000/api/site-stats 2>/dev/null || echo 'curl failed'"
expect {
    -re "assword" { send "$password\r"; exp_continue }
    "HTTP 200" { puts "  API OK" }
    "curl failed" { puts "  API not responding" }
    eof { }
    timeout { }
}
wait
puts ""

# Step 3: Reload nginx
puts "Step 3: Reload nginx..."
spawn ssh -o StrictHostKeyChecking=no ${user}@${server} "nginx -t 2>&1 && systemctl reload nginx 2>&1 && echo NGINX_RELOADED"
expect {
    -re "assword" { send "$password\r"; exp_continue }
    "NGINX_RELOADED" { puts "  Nginx reloaded" }
    "syntax is ok" { exp_continue }
    eof { }
    timeout { }
}
wait
puts ""

puts "=========================================="
puts "Done. Test: https://sailingsa.co.za/"
puts "=========================================="
