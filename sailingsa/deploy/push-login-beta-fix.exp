#!/usr/bin/expect -f
# Push session.js and index.html (login Beta fix) to server
set timeout 60
set password "TimAdd#072082"
set server "102.218.215.253"
set user "root"
set web_root "/var/www/sailingsa"
set script_dir [file dirname [info script]]
set project_root [file normalize "$script_dir/../.."]

spawn scp -o StrictHostKeyChecking=no $project_root/sailingsa/frontend/index.html ${user}@${server}:${web_root}/
expect {
    "password:" { send "$password\r"; exp_continue }
    eof { }
    timeout { puts "ERROR: timeout"; exit 1 }
}
wait

spawn scp -o StrictHostKeyChecking=no $project_root/sailingsa/frontend/js/session.js ${user}@${server}:${web_root}/js/
expect {
    "password:" { send "$password\r"; exp_continue }
    eof { }
    timeout { puts "ERROR: timeout"; exit 1 }
}
wait

spawn ssh -o StrictHostKeyChecking=no ${user}@${server} "chown www-data:www-data ${web_root}/index.html ${web_root}/js/session.js 2>/dev/null; ls -la ${web_root}/index.html ${web_root}/js/session.js"
expect {
    "password:" { send "$password\r"; exp_continue }
    eof { }
    timeout { puts "ERROR: timeout"; exit 1 }
}
wait
puts "Done."
