#!/usr/bin/expect -f
# TASK 1 — Mirror static assets to server (recursive SCP)
# Run from project root: expect sailingsa/deploy/mirror-static-assets.exp

set timeout 120
set password "TimAdd#072082"
set server "102.218.215.253"
set user "root"
set web_root "/var/www/sailingsa"
set api_dir "/var/www/sailingsa/api"

set script_dir [file dirname [info script]]
set project_root [file normalize "$script_dir/../.."]

puts "=========================================="
puts "TASK 1: Mirror static assets"
puts "=========================================="

# 1. assets/ (avatars, logos)
puts "Uploading sailingsa/frontend/assets/ -> ${web_root}/assets/"
spawn scp -r -o StrictHostKeyChecking=no $project_root/sailingsa/frontend/assets ${user}@${server}:${web_root}/
expect {
    "password:" { send "$password\r"; exp_continue }
    eof { }
    timeout { puts "ERROR: timeout"; exit 1 }
}
wait

# 2. artwork/ (TimAdvisor logo, Club logos) -> api/artwork for StaticFiles
puts "Uploading artwork/ -> ${api_dir}/artwork/"
spawn scp -r -o StrictHostKeyChecking=no $project_root/artwork ${user}@${server}:${api_dir}/
expect {
    "password:" { send "$password\r"; exp_continue }
    eof { }
    timeout { puts "ERROR: timeout"; exit 1 }
}
wait

# Chown
puts "Setting ownership www-data..."
spawn ssh -o StrictHostKeyChecking=no ${user}@${server} "chown -R www-data:www-data ${web_root}/assets ${api_dir}/artwork 2>/dev/null; ls -la ${web_root}/assets ${api_dir}/artwork 2>/dev/null | head -20"
expect {
    "password:" { send "$password\r"; exp_continue }
    eof { }
    timeout { puts "ERROR: timeout"; exit 1 }
}
wait
puts "Done."
