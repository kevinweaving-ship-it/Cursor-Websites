#!/usr/bin/expect -f
# 1) SELECT regatta 385 row; 2) curl twice 90s apart (prove ticking).
set timeout 120
set password "TimAdd#072082"
set server "102.218.215.253"
set user "root"

spawn ssh -o StrictHostKeyChecking=no ${user}@${server} "psql postgresql://sailors_user:SailSA_Pg_Beta2026!@localhost:5432/sailors_master -c \"SELECT regatta_id, start_date, end_date, result_status, as_at_time FROM regattas WHERE regatta_id='385-2026-hyc-cape-classic';\""
expect {
    -re "assword" { send "$password\r"; exp_continue }
    eof { }
    timeout { puts "ERROR: timeout"; exit 1 }
}
wait

spawn ssh -o StrictHostKeyChecking=no ${user}@${server} "echo '=== CURL 1 ===' && curl -s http://127.0.0.1:8000/regatta/hyc-cape-classic-2026 | grep -oE 'Results are \[^<\]+'; echo '=== SLEEP 90 ===' && sleep 90; echo '=== CURL 2 ===' && curl -s http://127.0.0.1:8000/regatta/hyc-cape-classic-2026 | grep -oE 'Results are \[^<\]+'"
expect {
    -re "assword" { send "$password\r"; exp_continue }
    eof { }
    timeout { puts "ERROR: timeout"; exit 1 }
}
wait
