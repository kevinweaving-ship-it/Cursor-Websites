#!/usr/bin/expect -f
# Run read-only query on live sailors_master. Raw psql output.
# From project root: expect sailingsa/deploy/query-live-regatta-385.exp
set timeout 30
set password "TimAdd#072082"
set server "102.218.215.253"
set user "root"

spawn ssh -o StrictHostKeyChecking=no ${user}@${server} "psql postgresql://sailors_user:SailSA_Pg_Beta2026!@localhost:5432/sailors_master -c \"SELECT regatta_id, result_status, as_at_time, start_date, end_date FROM regattas WHERE regatta_id = '385-2026-hyc-cape-classic';\""
expect {
    -re "assword" { send "$password\r"; exp_continue }
    eof { }
    timeout { puts "ERROR: timeout"; exit 1 }
}
wait
