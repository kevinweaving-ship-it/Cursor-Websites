#!/usr/bin/expect -f
# HARD PROOF: what process serves HTML on LIVE. No theory. Raw output.
set timeout 120
set password "TimAdd#072082"
set server "102.218.215.253"
set user "root"

set cmd "echo '=== 1 LISTEN 8000 ===' && ss -ltnp | grep 8000; echo '=== 2 PROCESS ===' && ps -ef | grep -E 'gunicorn|uvicorn' | grep -v grep; echo '=== 3 PER PID ===' && for pid in \$(ps -ef | grep -E 'gunicorn|uvicorn' | grep -v grep | awk '{print \$2}'); do echo \"--- PID \$pid ---\"; readlink -f /proc/\$pid/cwd; cat /proc/\$pid/cmdline | tr '\\0' ' '; echo; done; echo '=== 4 FROM CWD ===' && cd /var/www/sailingsa/api && sha256sum api.py && grep -n 'datetime.now' api.py && grep -n 'serve_regatta_standalone' api.py; echo '=== 5 LOCALHOST (1) ===' && curl -s http://127.0.0.1:8000/regatta/hyc-cape-classic-2026 | grep -oE 'Results are \[^<\]+'; echo '=== SLEEP 90 ===' && sleep 90; echo '=== 5 LOCALHOST (2) ===' && curl -s http://127.0.0.1:8000/regatta/hyc-cape-classic-2026 | grep -oE 'Results are \[^<\]+'"

spawn ssh -o StrictHostKeyChecking=no ${user}@${server} $cmd
expect {
    "password:" { send "$password\r"; exp_continue }
    eof { }
    timeout { puts "ERROR: timeout"; exit 1 }
}
wait
