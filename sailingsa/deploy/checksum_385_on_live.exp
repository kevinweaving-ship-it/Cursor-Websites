#!/usr/bin/expect -f
# Run checksum_regatta_385.py on live server (uses live DB).
set timeout 60
set password "TimAdd#072082"
set server "102.218.215.253"
set user "root"
set script_dir [file dirname [info script]]
set project_root [file normalize "$script_dir/../.."]
set py_path "$project_root/checksum_regatta_385.py"

spawn scp -o StrictHostKeyChecking=no $py_path ${user}@${server}:/tmp/
expect {
    -re "assword" { send "$password\r"; exp_continue }
    "100%" { }
    eof { }
    timeout { puts "ERROR: SCP timeout"; exit 1 }
}
wait

spawn ssh -o StrictHostKeyChecking=no ${user}@${server} "DATABASE_URL='postgresql://sailors_user:SailSA_Pg_Beta2026!@localhost:5432/sailors_master' /var/www/sailingsa/api/venv/bin/python3 /tmp/checksum_regatta_385.py"
expect {
    -re "assword" { send "$password\r"; exp_continue }
    "All checksums OK" { puts "\nLIVE: All checksums OK"; exit 0 }
    "FAIL" { puts "\nLIVE: Checksum FAIL"; exit 1 }
    eof { }
    timeout { puts "ERROR: timeout"; exit 1 }
}
wait
